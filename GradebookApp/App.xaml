<Application x:Class="GradebookApp.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:GradebookApp.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles/Controls.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <converters:StringNullOrEmptyToVisibilityConverter x:Key="EmptyToVisibleConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
