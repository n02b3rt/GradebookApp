<Window x:Class="GradebookApp.Views.TeacherDashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GradebookApp.Views"
        mc:Ignorable="d"
        Title="TeacherDashboard" Height="450" Width="800">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Nagłówek -->
        <TextBlock Text="Witaj, Nauczycielu!"
                   FontSize="26"
                   FontWeight="Bold"
                   Margin="0 0 0 20"/>

        <!-- Panel z przyciskami -->
        <UniformGrid Grid.Row="1" Columns="2" Rows="2" Margin="0 0 0 20" HorizontalAlignment="Stretch" VerticalAlignment="Top" >

            <!-- Karta: Przedmioty -->
            <Button Click="SubjectsButton_Click" Margin="10" Padding="20" Background="White" Cursor="Hand">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="icon" FontSize="32" HorizontalAlignment="Center"/>
                    <TextBlock Text="Moje przedmioty" FontSize="16" FontWeight="Bold" Margin="5" HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- Karta: Oceny -->
            <Button Click="GradesButton_Click" Margin="10" Padding="20" Background="White" Cursor="Hand">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="icon" FontSize="32" HorizontalAlignment="Center"/>
                    <TextBlock Text="Wystaw oceny" FontSize="16" FontWeight="Bold" Margin="5" HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- Karta: Lista uczniów -->
            <Button Click="StudentsButton_Click" Margin="10" Padding="20" Background="White" Cursor="Hand">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="icon" FontSize="32" HorizontalAlignment="Center"/>
                    <TextBlock Text="Uczniowie" FontSize="16" FontWeight="Bold" Margin="5" HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- Karta: Wyloguj -->
            <Button Click="LogoutButton_Click" Margin="10" Padding="20" Background="White" Cursor="Hand">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="icon" FontSize="32" HorizontalAlignment="Center"/>
                    <TextBlock Text="Wyloguj się" FontSize="16" FontWeight="Bold" Margin="5" HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>

        </UniformGrid>
    </Grid>
</Window>
