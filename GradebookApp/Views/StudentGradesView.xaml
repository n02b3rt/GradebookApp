<Window x:Class="GradebookApp.Views.StudentGradesView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GradebookApp.Views"
        mc:Ignorable="d"
        Title="StudentGradesView" Height="450" Width="800">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Nagłówek -->
        <TextBlock x:Name="StudentNameTextBlock"
                   FontSize="20"
                   FontWeight="Bold"
                   Margin="0 0 0 10"/>

        <!-- Tabela ocen -->
        <DataGrid x:Name="GradesDataGrid"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  Margin="0 10 0 10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Przedmiot" Binding="{Binding Subject.Name}" Width="*"/>
                <DataGridTextColumn Header="Ocena" Binding="{Binding Value}" Width="100"/>
                <DataGridTextColumn Header="Data" Binding="{Binding Date, StringFormat=yyyy-MM-dd}" Width="150"/>
                <DataGridTextColumn Header="Komentarz" Binding="{Binding Comment}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Średnia -->
        <TextBlock x:Name="AverageTextBlock"
                   Grid.Row="2"
                   FontSize="14"
                   FontWeight="SemiBold"
                   Text="Średnia ocen: -"
                   HorizontalAlignment="Right"/>
    </Grid>
</Window>
