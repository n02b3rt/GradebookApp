<Window x:Class="GradebookApp.Views.GradesOverviewView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GradebookApp.Views"
        mc:Ignorable="d"
        Title="GradesOverviewView" Height="450" Width="800">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Filtry -->
        <StackPanel Orientation="Horizontal" Margin="0 0 0 10" HorizontalAlignment="Left" >
            <TextBlock Text="Klasa:" VerticalAlignment="Center"/>
            <ComboBox x:Name="ClassComboBox" Width="100" SelectionChanged="Filters_Changed"/>

            <TextBlock Text="Przedmiot:" VerticalAlignment="Center"/>
            <ComboBox x:Name="SubjectComboBox" Width="150" SelectionChanged="Filters_Changed"/>
        </StackPanel>

        <!-- Tabela ocen -->
        <DataGrid x:Name="GradesDataGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Uczeń" Binding="{Binding StudentName}" Width="*"/>
                <DataGridTextColumn Header="Ocena" Binding="{Binding Value}" Width="100"/>
                <DataGridTextColumn Header="Przedmiot" Binding="{Binding SubjectName}" Width="150"/>
                <DataGridTextColumn Header="Data" Binding="{Binding Date}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Średnia -->
        <TextBlock x:Name="AverageTextBlock" Grid.Row="2" FontSize="14" FontWeight="Bold" Margin="0 10 0 0"/>
    </Grid>
</Window>
